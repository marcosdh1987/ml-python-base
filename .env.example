# =============================================================================
# OpenCode runtime configuration (copy to .env and edit).
#
# opencode.json reads these via {env:...} interpolation. opencode auto-loads a
# project .env; `make opencode` also loads it for you. Keep comments on their OWN
# lines — inline "VALUE  # comment" can leak into the value with some parsers.
# .env is gitignored: your IPs/keys never get committed.
# =============================================================================

# --- Active models (format: provider/model-id) -------------------------------
# IMPORTANT: the model id must EXACTLY match what your server serves. List them:
#   make opencode-doctor        (checks reachability)
#   opencode models             (lists every provider/model opencode sees)
#   curl $OLLAMA_BASE_URL/models | python3 -m json.tool      (Ollama ids)
#   curl $LMSTUDIO_BASE_URL/models | python3 -m json.tool    (LM Studio ids)
# Main tier — used by the `build` agent (EXECUTION). Self-hosted.
OPENCODE_MODEL=lmstudio/qwen/qwen3-coder-30b
# Lightweight tier (titles, quick tasks):
OPENCODE_SMALL_MODEL=ollama/qwen3:8b
# PLAN tier — used by the built-in `plan` agent (Tab to switch). Big "thinking" model.
# Default: OpenCode Zen's free Nemotron Ultra — only needs `opencode auth login`
# (no extra API key). Other free Zen options: opencode/deepseek-v4-flash-free,
# opencode/mimo-v2.5-free, opencode/north-mini-code-free.
OPENCODE_MODEL_PLAN=opencode/nemotron-3-ultra-free
# Alternatives (uncomment one): NVIDIA NIM (needs NVIDIA_API_KEY) or any OpenRouter :free
#   OPENCODE_MODEL_PLAN=nvidia/nvidia/nemotron-3-super-120b-a12b

# --- Self-hosted endpoints (OpenAI-compatible, must end in /v1) --------------
# Replace with your hosts. For LM Studio, also list its served ids under
# provider.lmstudio.models in opencode.json (catalog defaults point at localhost).
OLLAMA_BASE_URL=http://192.168.0.155:11434/v1
LMSTUDIO_BASE_URL=http://192.168.0.223:1234/v1

# --- Cloud providers ---------------------------------------------------------
# OpenCode Zen (default planner above) is built-in: run `opencode auth login` once.
# Its *-free models cost nothing; no key needed here.
#
# NVIDIA NIM is OPTIONAL — only if you switch OPENCODE_MODEL_PLAN to an nvidia/ model.
# Free key at https://build.nvidia.com -> "Get API Key". Leave empty otherwise.
NVIDIA_API_KEY=

# OpenAI is also built-in via `opencode auth login` (or OPENAI_API_KEY).
#   OPENCODE_MODEL=openai/gpt-4o
# OPENAI_API_KEY=sk-...
