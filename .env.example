# =============================================================================
# OpenCode runtime configuration (copy to .env and edit).
#
# opencode.json reads these via {env:...} interpolation. They must be present in
# the process environment when opencode runs — use `make opencode` (loads .env
# for you), `direnv`, or `set -a; . ./.env; set +a` before launching opencode.
#
# .env is gitignored: your IPs/keys never get committed. This template ships
# only this example.
# =============================================================================

# --- Active models (format: provider/model-id) -------------------------------
# Pick from the providers below. Two tiers: main + lightweight.
OPENCODE_MODEL=ollama/qwen2.5-coder:32b          # main tier (planning, coding)
OPENCODE_SMALL_MODEL=ollama/llama3.1:8b          # lightweight tier (titles, quick tasks)

# --- Self-hosted endpoints (OpenAI-compatible, must end in /v1) ---------------
# Example values match a typical LAN GPU setup — replace with your hosts.
OLLAMA_BASE_URL=http://192.168.0.155:11434/v1    # PC running Ollama
LMSTUDIO_BASE_URL=http://192.168.0.223:1234/v1   # PC running LM Studio

# To use LM Studio as the active model instead, e.g.:
#   OPENCODE_MODEL=lmstudio/your-loaded-model-id
# (find the exact id in LM Studio → Developer/Server tab, then list it under
#  provider.lmstudio.models in opencode.json)

# --- Cloud providers (optional) ----------------------------------------------
# OpenAI and OpenCode Zen are built-in: prefer `opencode auth login` (stored in
# the OS keychain). Set a key here only if you want it via env instead.
#   OPENCODE_MODEL=openai/gpt-4o          # OpenAI
#   OPENCODE_MODEL=opencode/gpt-5.5       # OpenCode Zen (curated models)
# OPENAI_API_KEY=sk-...
