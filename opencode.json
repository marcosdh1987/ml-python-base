{
  "$schema": "https://opencode.ai/config.json",
  "instructions": "OPENCODE.md",
  "model": "{env:OPENCODE_MODEL}",
  "small_model": "{env:OPENCODE_SMALL_MODEL}",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (self-hosted)",
      "options": {
        "baseURL": "{env:OLLAMA_BASE_URL}"
      },
      "models": {
        "qwen2.5-coder:32b": { "name": "Qwen2.5 Coder 32B (large tier)" },
        "qwen2.5-coder:14b": { "name": "Qwen2.5 Coder 14B (mid tier)" },
        "llama3.1:8b": { "name": "Llama 3.1 8B (small tier)" }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (self-hosted)",
      "options": {
        "baseURL": "{env:LMSTUDIO_BASE_URL}"
      },
      "models": {
        "local-model": { "name": "LM Studio loaded model (rename to your model id)" }
      }
    }
  }
}
